# Frontend (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
# Optional override; auto-derived from VITE_SUPABASE_URL if omitted
VITE_SUPABASE_FUNCTIONS_BASE=https://<ref>.functions.supabase.co/functions/v1

# Feature flags
VITE_FEATURE_LIVE_SHOWS=false

# Site
VITE_SITE_URL=http://localhost:5173

# Server/Functions (set with `supabase secrets set`)
SITE_URL=http://localhost:5173
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (pick one provider)
EMAIL_FROM=dev@localhost
RESEND_API_KEY=re_...
# POSTMARK_API_TOKEN=...
# SENDGRID_API_KEY=...

# Optional SMS
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# ─────────────────────────────────────────────────────────
# ZingLots .env.example  (no secrets; example values only)
# copy to .env.local for local dev; set same keys in Vercel
# ─────────────────────────────────────────────────────────

# Frontend (Vite) — exposed in browser
VITE_SUPABASE_URL=https://huebxglhbenulbcftzdq.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test
VITE_ENABLE_DEV_WIDGETS=false

# Server-only (do NOT prefix with VITE_)
SITE_URL=https://zinglots.com
STRIPE_SECRET_KEY=sk_live_or_test
STRIPE_WEBHOOK_SECRET=whsec_xxx
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret

# CORS / Functions
ALLOWED_ORIGINS=https://zinglots.com,https://*.vercel.app,http://localhost:5173

# Node/Build
NODE_ENV=development

