# ZingLots Production Environment Variables
# Copy this file to .env.local and fill in your values

# Site Configuration
SITE_URL=https://zinglots.com
NEXT_PUBLIC_SITE_URL=https://zinglots.com

# Supabase Configuration
VITE_SUPABASE_URL=https://huebxglhbenulbcftzdq.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.huebxglhbenulbcftzdq.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.huebxglhbenulbcftzdq.supabase.co:5432/postgres

# Authentication
JWT_SECRET=your-jwt-secret-here
NEXTAUTH_URL=https://zinglots.com
NEXTAUTH_SECRET=your-nextauth-secret-here

# Email (SendGrid/Resend)
EMAIL_FROM=noreply@zinglots.com
RESEND_API_KEY=your-resend-api-key-here

# Storage
STORAGE_BUCKET=zinglots-media
NEXT_PUBLIC_STORAGE_URL=https://huebxglhbenulbcftzdq.supabase.co/storage/v1

# Payment Processing (Stripe)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here
STRIPE_SECRET_KEY=sk_live_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# AI Services (Anthropic/OpenAI)
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_PAYMENT_PROCESSING=true
ENABLE_EMAIL_NOTIFICATIONS=true

# Security
CORS_ORIGINS=https://zinglots.com,https://www.zinglots.com,https://zing-lots-com.vercel.app
ALLOWED_HOSTS=zinglots.com,www.zinglots.com
SECURE_HEADERS=true
RATE_LIMIT_PER_MINUTE=60

# Development (remove in production)
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
