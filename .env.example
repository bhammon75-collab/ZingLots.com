# ZingLots Production Environment Variables
# Copy this file to .env.local and fill in your values

# ==========================================
# SITE CONFIGURATION
# ==========================================
SITE_URL=https://zinglots.com

# ==========================================
# SUPABASE CONFIGURATION
# ==========================================
# Frontend Client Variables (Vite)
VITE_SUPABASE_URL=https://huebxglhbenulbcftzdq.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Edge Functions Variables
SUPABASE_URL=https://huebxglhbenulbcftzdq.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database URLs
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.huebxglhbenulbcftzdq.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.huebxglhbenulbcftzdq.supabase.co:5432/postgres

# ==========================================
# PAYMENT PROCESSING
# ==========================================
# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here
STRIPE_SECRET_KEY=sk_live_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# PayPal Configuration
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_API_BASE=https://api-m.paypal.com

# ==========================================
# LIVEKIT CONFIGURATION
# ==========================================
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ==========================================
# AUTHENTICATION
# ==========================================
JWT_SECRET=your-jwt-secret-here

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
EMAIL_FROM=noreply@zinglots.com
RESEND_API_KEY=your-resend-api-key-here

# ==========================================
# STORAGE
# ==========================================
STORAGE_BUCKET=zinglots-media

# ==========================================
# AI SERVICES (Optional)
# ==========================================
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here

# ==========================================
# ANALYTICS (Optional)
# ==========================================
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_POSTHOG_KEY=your-posthog-key
VITE_POSTHOG_HOST=https://app.posthog.com

# ==========================================
# MONITORING (Optional)
# ==========================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_AI_FEATURES=true
ENABLE_PAYMENT_PROCESSING=true
ENABLE_EMAIL_NOTIFICATIONS=true

# ==========================================
# SECURITY
# ==========================================
CORS_ORIGINS=https://zinglots.com,https://www.zinglots.com,https://zing-lots-com.vercel.app
ALLOWED_HOSTS=zinglots.com,www.zinglots.com
SECURE_HEADERS=true
RATE_LIMIT_PER_MINUTE=60

# ==========================================
# ENVIRONMENT
# ==========================================
NODE_ENV=production
