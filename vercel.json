{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/(.*\\..*)", "destination": "/$1" },
    { "source": "/((?!api/|assets/|.*\\.).*)", "destination": "/" }
  ],
  "installCommand": "npm install",
  "buildCommand": "npm run build"
}